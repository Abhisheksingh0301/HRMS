<title>
    <%= title %>
</title>

<link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/font-awesome/4.4.0/css/font-awesome.min.css" />
<script src="https://kit.fontawesome.com/00d76a4bef.js" crossorigin="anonymous"></script>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<link rel='stylesheet' href='/stylesheets/style.css'>
<script src="/js/jquery.js"></script>

<%- include('header'); -%>

<!-- PAGE HEADER -->
<section class="bg-gradient-to-r from-blue-600 to-indigo-700 py-4 shadow-md">

    <div class="max-w-7xl mx-auto px-4">

        <div class="flex items-center justify-between">

            <div>

                <h1 class="text-2xl font-bold text-white flex items-center gap-3">

                    <i class="fa fa-calendar-check-o"></i>

                    <%= title %>

                </h1>

                <p class="text-blue-100 text-sm mt-1">
                    Employee Attendance & Leave Management
                </p>

            </div>

            <div class="hidden md:flex bg-white/10 backdrop-blur-md text-white px-4 py-2 rounded-xl text-sm font-semibold">

                <i class="fa fa-users mr-2"></i>
                HRMS Portal

            </div>

        </div>

    </div>

</section>

<!-- MAIN CONTENT -->
<div class="max-w-7xl mx-auto px-4 py-5">

    <!-- FORM CARD -->
    <div class="bg-white rounded-2xl shadow-lg border border-slate-200">

        <!-- CARD HEADER -->
        <div class="px-6 py-4 border-b border-slate-200 flex items-center justify-between">

            <div>

                <h2 class="text-lg font-bold text-slate-800">
                    Add Attendance / Leave
                </h2>

                <p class="text-slate-500 text-sm">
                    Fill attendance details
                </p>

            </div>

        </div>

        <!-- FORM -->
        <form action="/addatt/" method="POST" class="p-6">

            <div class="grid grid-cols-1 md:grid-cols-4 gap-4 items-end">

                <!-- EMPLOYEE -->
                <div>

                    <label class="block mb-2 text-sm font-semibold text-slate-700">
                        Employee
                    </label>

                    <select
                        id="nm"
                        name="empnm"
                        required
                        class="w-full border border-slate-300 rounded-lg px-3 py-2.5 text-sm focus:ring-2 focus:ring-blue-200 focus:border-blue-500 outline-none">

                        <option value="0">Select</option>

                        <% for (var i=0; i<empdata.length; i++){ %>

                        <option
                            value='<%= empdata[i].emp_name %>'
                            <% if(empdata[i].emp_name==attData.emp_name ){ %>
                            selected
                            <% } %>>

                            <%= empdata[i].emp_name %>

                        </option>

                        <% } %>

                    </select>

                </div>

                <!-- LEAVE -->
                <div>

                    <label class="block mb-2 text-sm font-semibold text-slate-700">
                        Leave Type
                    </label>

                    <select
                        id="lv"
                        name="lvcat"
                        required
                        class="w-full border border-slate-300 rounded-lg px-3 py-2.5 text-sm focus:ring-2 focus:ring-blue-200 focus:border-blue-500 outline-none">

                        <option value="0">Select</option>

                        <% for (var i=0; i<leavedata.length; i++){ %>

                        <option
                            value='<%= leavedata[i].leave_abb %>'
                            <% if(leavedata[i].leave_abb==attData.leave_type ){ %>
                            selected
                            <% } %>>

                            <%= leavedata[i].leave_abb %>

                        </option>

                        <% } %>

                    </select>

                </div>

                <!-- DATE -->
                <div>

                    <label class="block mb-2 text-sm font-semibold text-slate-700">
                        Dates
                    </label>

                    <input
                        type="text"
                        id="dt"
                        name="dt"
                        placeholder="Select dates"
                        required
                        class="w-full border border-slate-300 rounded-lg px-3 py-2.5 text-sm focus:ring-2 focus:ring-blue-200 focus:border-blue-500 outline-none">

                </div>

                <!-- BUTTON -->
                <div>

                    <button
                        type="submit"
                        class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold px-4 py-2.5 rounded-lg shadow transition duration-200 text-sm">

                        <i class="fa fa-save mr-2"></i>

                        Submit

                    </button>

                </div>

            </div>

        </form>

    </div>

    <!-- TABLE -->
    <% if(topattData && topattData.length > 0){ %>

    <div class="bg-white rounded-2xl shadow-lg border border-slate-200 mt-5 overflow-hidden">

        <!-- HEADER -->
        <div class="px-6 py-4 border-b border-slate-200 flex items-center justify-between">

            <div>

                <h2 class="text-lg font-bold text-slate-800">
                    Recent Entries
                </h2>

                <p class="text-slate-500 text-sm">
                    Last 5 attendance records
                </p>

            </div>

            <span class="bg-slate-100 text-slate-600 px-3 py-1 rounded-lg text-xs font-semibold">

                Live Records

            </span>

        </div>

        <!-- TABLE -->
        <div class="overflow-x-auto">

            <table class="min-w-full text-sm">

                <thead class="bg-blue-600 text-white">

                    <tr>

                        <th class="px-5 py-3 text-left font-semibold">
                            Employee
                        </th>

                        <th class="px-5 py-3 text-left font-semibold">
                            Leave
                        </th>

                        <th class="px-5 py-3 text-left font-semibold">
                            Leave Date
                        </th>

                        <th class="px-5 py-3 text-left font-semibold">
                            Entry Date
                        </th>

                    </tr>

                </thead>

                <tbody class="divide-y divide-slate-200 bg-white">

                    <% topattData.forEach(function(att){ %>

                    <tr class="hover:bg-blue-50 transition">

                        <td class="px-5 py-3 font-semibold text-slate-800">

                            <%= att.emp_name %>

                        </td>

                        <td class="px-5 py-3">

                            <span class="bg-blue-100 text-blue-700 px-2.5 py-1 rounded-full text-xs font-bold">

                                <%= att.leave_type %>

                            </span>

                        </td>

                        <td class="px-5 py-3 text-slate-600">

                            <%= moment(att.leave_date).format('DD-MMM-YYYY') %>

                        </td>

                        <td class="px-5 py-3 text-slate-600">

                            <%= moment(att.entrydt).format('DD-MMM-YYYY hh:mm A') %>

                        </td>

                    </tr>

                    <% }); %>

                </tbody>

            </table>

        </div>

    </div>

    <% } %>

</div>

<%- include('footer'); -%>

<script>

    flatpickr("#dt", {

        mode: "multiple",

        dateFormat: "Y-m-d",

        disable: [

            function (date) {

                return date.getDay() === 0;

            }

        ]

    });

</script>