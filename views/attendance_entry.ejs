<title>
    <%= title %>
</title>
<link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/font-awesome/4.4.0/css/font-awesome.min.css" />
<script src="https://kit.fontawesome.com/00d76a4bef.js" crossorigin="anonymous"></script>
<link rel='stylesheet' href='/stylesheets/style.css'>
<script src="/js/jquery.js"></script>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>

<%- include('header'); -%>
    <section class="featured">
        <div class="content-wrapper">
            <h1 id="myHeader" class="text-4xl">
                <%= title %>
            </h1>
        </div>
    </section>
    <div class=" flex flex-col  items-center justify-center m-auto mt-5">
        <form action="/addatt/" method="POST"
            class="bg-slate-300 sm:flex sm:flex-row flex flex-col justify-center items-center  w-full sm:w-[80%] mx-4 rounded-lg">

            <select id="nm" name="empnm" class="text-sm w-3/4 mr-3  py-4 px-4 border border-gray-200  rounded mb-2">
                <option value="0"> Select name</option>
                <% for (var i=0; i<empdata.length; i++){ %>
                    <option value='<%= empdata[i].emp_name %>' <% if(empdata[i].emp_name==attData.emp_name ){ %>
                        selected <% } %>>
                            <%= empdata[i].emp_name %>
                    </option>
                    <% } %>
            </select>
            <select id="lv" name="lvcat" class="text-sm w-3/4 mr-3  py-4 px-4 border border-gray-200  rounded mb-2">
                <option value="0"> Select leave</option>
                <% for (var i=0; i<leavedata.length; i++){ %>
                    <option value='<%= leavedata[i].leave_abb %>' <% if(leavedata[i].leave_abb==attData.leave_type ){ %>
                        selected <% } %>>
                            <%= leavedata[i].leave_abb %>
                    </option>
                    <% } %>
            </select>
            <input type="text" id="dt" name="dt" placeholder="Select multiple dates"
                class="text-sm w-3/4 mr-3 py-4 px-4 border border-gray-200 rounded mb-2" required>


            <button type="submit"
                class="bg-red-400 py-4 w-3/4 sm:w-1/2 mb-2 hover:bg-red-500 font-bold px-2 rounded-lg hover:rounded-full">
                Submit
            </button>
        </form>
        <% if(topattData && topattData.length> 0){ %>
            <table class="table-auto border mt-5">
                <tr>
                    <th colspan="4" class="py-2 px-4 border-b text-sm">Last 5 Entries</th>
                </tr>
                <tr>
                    <th class="py-2 px-4 border-b text-sm">Emp name</th>
                    <th class="py-2 px-4 border-b text-sm">Leave type</th>
                    <th class="py-2 px-4 border-b text-sm">Leave date</th>
                    <th class="py-2 px-4 border-b text-sm">Entry date</th>
                </tr>

                <% topattData.forEach(function(att){ %>
                    <tr>
                        <td class="py-2 px-4 border-b text-sm">
                            <%= att.emp_name %>
                        </td>
                        <td class="py-2 px-4 border-b text-sm">
                            <%= att.leave_type %>
                        </td>
                        <td class="py-2 px-4 border-b text-sm">
                            <%= moment(att.leave_date).format('DD-MMM-YYYY') %>
                        </td>
                        <td class="py-2 px-4 border-b text-sm">
                            <%= moment(att.entrydt).format('DD-MMM-YYYY hh:mm:ss A') %>
                        </td>
                    </tr>
                    <% }); %>
            </table>
            <% } %>


    </div>

    <%- include('footer'); -%>

        <script>
            flatpickr("#dt", {
                mode: "multiple",
                dateFormat: "Y-m-d",

                disable: [
                    function (date) {
                        // 0 = Sunday
                        return date.getDay() === 0;
                    }
                ]
            });
        </script>