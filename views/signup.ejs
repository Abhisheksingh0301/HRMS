<title>
    <%= title %>
</title>

<link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/font-awesome/4.4.0/css/font-awesome.min.css" />
<script src="https://kit.fontawesome.com/00d76a4bef.js" crossorigin="anonymous"></script>

<link rel='stylesheet' href='/stylesheets/style.css'>
<script src="/js/jquery.js"></script>

<%- include('header'); -%>

<!-- PAGE HEADER -->
<section class="bg-gradient-to-r from-emerald-600 to-green-700 py-3 shadow-md">

    <div class="max-w-7xl mx-auto px-4">

        <div class="flex items-center justify-between">

            <div>
                <h1 class="text-xl font-bold text-white flex items-center gap-3">
                    <i class="fa fa-user-plus"></i>
                    <%= title %>
                </h1>

                <p class="text-green-100 text-xs mt-1">
                    Create new employee account
                </p>
            </div>

            <div class="hidden md:flex bg-white/10 backdrop-blur-md text-white px-3 py-1.5 rounded-lg text-xs font-semibold">
                HRMS Portal
            </div>

        </div>

    </div>

</section>

<!-- MAIN CONTENT (NO FORCED FULL HEIGHT) -->
<div class="bg-slate-50 px-4 py-6">

    <div class="max-w-md mx-auto">

        <!-- CARD -->
        <div class="bg-white rounded-2xl shadow-md border border-slate-200 overflow-hidden">

            <!-- HEADER -->
            <div class="px-5 py-3 border-b border-slate-200 text-center">
                <h2 class="text-lg font-bold text-slate-800">
                    Sign Up
                </h2>
                <p class="text-xs text-slate-500">
                    Create your account
                </p>
            </div>

            <!-- FORM -->
            <form action="/signup" method="post" class="p-4 space-y-3">

                <!-- USERNAME -->
                <div>
                    <label class="block text-xs font-semibold text-slate-700 mb-1">
                        Username
                    </label>

                    <select id="empname" name="empname" required
                        class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-emerald-200 focus:border-emerald-500 outline-none">

                        <option value="">Select name</option>

                        <% for (var i=0; i<empdata.length; i++){ %>
                            <option value="<%= empdata[i].emp_name %>">
                                <%= empdata[i].emp_name %>
                            </option>
                        <% } %>

                    </select>
                </div>

                <!-- PASSWORD -->
                <div>
                    <label class="block text-xs font-semibold text-slate-700 mb-1">
                        Password
                    </label>

                    <input type="password" id="txtpwd" name="txtpwd" required
                        class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-emerald-200 focus:border-emerald-500 outline-none">
                </div>

                <!-- CONFIRM PASSWORD -->
                <div>
                    <label class="block text-xs font-semibold text-slate-700 mb-1">
                        Confirm Password
                    </label>

                    <input type="password" id="txtcnfrmpwd" name="txtcnfrmpwd" required
                        class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-emerald-200 focus:border-emerald-500 outline-none">
                </div>

                <!-- BUTTON -->
                <button type="submit"
                    class="w-full bg-emerald-600 hover:bg-emerald-700 text-white font-semibold py-2 rounded-lg shadow transition">

                    Signup

                </button>

            </form>

        </div>

    </div>

</div>

<%- include('footer'); -%>