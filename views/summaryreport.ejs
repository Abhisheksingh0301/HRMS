<title>
    <%= title %>
</title>

<link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/font-awesome/4.4.0/css/font-awesome.min.css" />
<script src="https://kit.fontawesome.com/00d76a4bef.js" crossorigin="anonymous"></script>

<link rel='stylesheet' href='/stylesheets/style.css'>
<script src="/js/jquery.js"></script>

<%- include('header'); -%>

<!-- PAGE HEADER -->
<section class="bg-gradient-to-r from-green-600 to-emerald-700 py-4 shadow-md">

    <div class="max-w-7xl mx-auto px-4">

        <h1 class="text-2xl font-bold text-white flex items-center gap-3">

            <i class="fa fa-calendar"></i>

            <%= title %>

        </h1>

        <p class="text-green-100 text-sm mt-1">
            Generate Attendance Summary Report
        </p>

    </div>

</section>

<!-- MAIN -->
<div class="max-w-4xl mx-auto px-4 py-6">

    <!-- FORM CARD -->
    <div class="bg-white rounded-2xl shadow-lg border border-slate-200 p-6">

        <form action="/summaryrpt/" method="POST" target="_blank"
            class="grid grid-cols-1 md:grid-cols-3 gap-4 items-end">

            <!-- START DATE -->
            <div>

                <label class="block text-sm font-semibold text-slate-700 mb-2">
                    Start Date
                </label>

                <input
                    type="date"
                    id="stdt"
                    name="stdt"
                    required
                    class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-green-200 focus:border-green-500 outline-none">

            </div>

            <!-- END DATE -->
            <div>

                <label class="block text-sm font-semibold text-slate-700 mb-2">
                    End Date
                </label>

                <input
                    type="date"
                    id="enddt"
                    name="enddt"
                    required
                    class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-green-200 focus:border-green-500 outline-none">

            </div>

            <!-- BUTTON -->
            <div>

                <button type="submit"
                    class="w-full bg-green-600 hover:bg-green-700 text-white font-semibold py-2.5 rounded-lg shadow transition">

                    <i class="fa fa-search mr-2"></i>

                    Generate Report

                </button>

            </div>

        </form>

    </div>

</div>

<%- include('footer'); -%>