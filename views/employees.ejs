<title>
    <%= title %>
</title>

<link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/font-awesome/4.4.0/css/font-awesome.min.css" />
<script src="https://kit.fontawesome.com/00d76a4bef.js" crossorigin="anonymous"></script>

<link rel='stylesheet' href='/stylesheets/style.css'>
<script src="/js/jquery.js"></script>

<%- include('header'); -%>

<!-- HEADER -->
<section class="bg-gradient-to-r from-emerald-600 to-green-700 py-3 shadow-md">

    <div class="max-w-7xl mx-auto px-4">

        <h1 class="text-xl font-bold text-white flex items-center gap-2">

            <i class="fa fa-user-plus"></i>

            Add Employee

        </h1>

    </div>

</section>

<!-- MAIN -->
<div class="max-w-6xl mx-auto px-4 py-3">

    <div class="bg-white rounded-xl shadow-md border border-slate-200 grid grid-cols-1 md:grid-cols-2 overflow-hidden">

        <!-- LEFT INFO (COMPACT) -->
        <div class="p-5 flex items-center bg-slate-50">

            <p class="text-sm leading-relaxed text-slate-700">

                Add employees to keep attendance records accurate and organized.
                This helps generate precise reports, track patterns, and improve HR efficiency.

            </p>

        </div>

        <!-- RIGHT FORM -->
        <div class="p-4">

            <form action="/addemp/" method="POST" class="space-y-3">

                <!-- NAME -->
                <div class="relative">

                    <input type="text" name="empname" required
                        class="peer w-full border border-slate-300 rounded-lg px-3 pt-5 pb-2 text-sm focus:border-emerald-500 outline-none"
                        placeholder=" ">

                    <label class="absolute left-3 top-1 text-xs text-slate-500">
                        Employee Name
                    </label>

                </div>

                <!-- JOIN YEAR -->
                <div class="relative">

                    <input type="number" name="joinyr" min="2006"
                        class="peer w-full border border-slate-300 rounded-lg px-3 pt-5 pb-2 text-sm"
                        placeholder=" ">

                    <label class="absolute left-3 top-1 text-xs text-slate-500">
                        Joining Year
                    </label>

                </div>

                <!-- GENDER -->
                <div class="relative">

                    <select name="cmbGender"
                        class="peer w-full border border-slate-300 rounded-lg px-3 pt-5 pb-2 text-sm">

                        <option value="Male" selected>Male</option>
                        <option value="Female">Female</option>

                    </select>

                    <label class="absolute left-3 top-1 text-xs text-slate-500">
                        Gender
                    </label>

                </div>

                <!-- MOBILE -->
                <div class="relative">

                    <input type="number" name="txtmob" required min="5555555555" max="9999999999"
                        class="peer w-full border border-slate-300 rounded-lg px-3 pt-5 pb-2 text-sm"
                        placeholder=" ">

                    <label class="absolute left-3 top-1 text-xs text-slate-500">
                        Mobile Number
                    </label>

                </div>

                <!-- REMARKS -->
                <div class="relative">

                    <input type="text" name="rmrk"
                        class="peer w-full border border-slate-300 rounded-lg px-3 pt-5 pb-2 text-sm"
                        placeholder=" ">

                    <label class="absolute left-3 top-1 text-xs text-slate-500">
                        Remarks (optional)
                    </label>

                </div>

                <!-- BUTTON -->
                <button type="submit"
                    class="w-full bg-emerald-600 hover:bg-emerald-700 text-white font-semibold py-2 rounded-lg text-sm transition">

                    <i class="fa fa-save mr-1"></i>
                    Save Employee

                </button>

            </form>

        </div>

    </div>

</div>

<%- include('footer'); -%>