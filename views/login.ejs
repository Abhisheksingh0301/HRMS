<title>
    <%= title %>
</title>

<link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/font-awesome/4.4.0/css/font-awesome.min.css" />
<script src="https://kit.fontawesome.com/00d76a4bef.js" crossorigin="anonymous"></script>

<link rel='stylesheet' href='/stylesheets/style.css'>
<script src="/js/jquery.js"></script>

<%- include('header'); -%>

<!-- FULL SCREEN WRAPPER (NO SCROLL) -->
<div class="h-screen overflow-hidden flex flex-col bg-slate-50">

    <!-- HEADER (fixed height) -->
    <section class="bg-gradient-to-r from-indigo-600 to-blue-700 shadow-md shrink-0">

        <div class="max-w-7xl mx-auto px-4 py-3">

            <div class="flex items-center justify-between">

                <div>
                    <h1 class="text-xl font-bold text-white flex items-center gap-3">
                        <i class="fa fa-sign-in"></i>
                        <%= title %>
                    </h1>

                    <p class="text-blue-100 text-xs mt-0.5">
                        Secure Employee Login Portal
                    </p>
                </div>

                <div class="hidden md:flex bg-white/10 backdrop-blur-md text-white px-3 py-1.5 rounded-lg text-xs font-semibold">
                    HRMS System
                </div>

            </div>

        </div>

    </section>

    <!-- CENTER CONTENT (fills remaining height) -->
<div class="flex-1 flex items-start justify-center px-4 pt-6">

        <div class="w-full max-w-md">

            <!-- LOGIN CARD -->
            <div class="bg-white rounded-2xl shadow-lg border border-slate-200 overflow-hidden">

                <!-- HEADER -->
                <div class="px-6 py-4 border-b border-slate-200 text-center">
                    <h2 class="text-lg font-bold text-slate-800">
                        Welcome Back
                    </h2>
                    <p class="text-xs text-slate-500">
                        Login to continue
                    </p>
                </div>

                <!-- FORM -->
                <form action="/login" method="POST" class="p-5 space-y-4">

                    <!-- USER -->
                    <div>
                        <label class="block text-xs font-semibold text-slate-700 mb-1">
                            Username
                        </label>

                        <select id="txtuser" name="txtuser"
                            class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-200 focus:border-blue-500 outline-none"
                            required>

                            <option value="">Select User</option>

                            <% for (var i=0; i<empdata.length; i++){ %>
                                <option value="<%= empdata[i].emp_name %>">
                                    <%= empdata[i].emp_name %>
                                </option>
                            <% } %>

                        </select>
                    </div>

                    <!-- PASSWORD -->
                    <div>
                        <label class="block text-xs font-semibold text-slate-700 mb-1">
                            Password
                        </label>

                        <input type="password" id="txtpwd" name="txtpwd" required
                            class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-200 focus:border-blue-500 outline-none">
                    </div>

                    <!-- BUTTON -->
                    <button type="submit"
                        class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 rounded-lg shadow transition">

                        <i class="fa fa-sign-in mr-2"></i>
                        Login

                    </button>

                </form>

                <!-- FOOTER -->
                <div class="px-6 pb-3 text-center">
                    <p class="text-xs text-slate-600">
                        Don’t have an account?
                        <a href="/signup" class="text-blue-600 hover:underline font-semibold">
                            Sign up
                        </a>
                    </p>
                </div>

            </div>

        </div>

    </div>

</div>

<%- include('footer'); -%>