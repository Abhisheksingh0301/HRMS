<title>
    <%= title %>
</title>

<link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/font-awesome/4.4.0/css/font-awesome.min.css" />
<script src="https://kit.fontawesome.com/00d76a4bef.js" crossorigin="anonymous"></script>
<link rel='stylesheet' href='/stylesheets/style.css'>
<script src="/js/jquery.js"></script>

<%- include('header'); -%>

<section class="featured">
    <div class="container">
        <div class="content-wrapper">
            <h1 id="myHeader">
                <i class="fa fa-users"></i>
                <%= title %>
            </h1>
            <p style="text-align:center; color: var(--text-light); margin-top:8px;">
                Employee Management Dashboard
            </p>
        </div>
    </div>
</section>

<div class="container" style="padding: 30px 0 60px;">

    <% if(employeelist.length > 0){ %>

    <div class="card">

        <!-- TOP ACTION BAR -->
        <div class="flex-between" style="margin-bottom: 20px; flex-wrap: wrap; gap: 12px;">

            <h2 style="font-size: 1.3rem;">
                Employee Records
            </h2>

            <a href="./employees" class="btn btn-primary">
                <i class="fa fa-plus"></i>
                Add Employee
            </a>

        </div>

        <!-- TABLE -->
        <div style="overflow-x:auto;">

            <table>

                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Joining Year</th>
                        <th>Gender</th>
                        <th>Mobile No</th>
                        <th>Remarks</th>
                        <th style="text-align:center;">Action</th>
                    </tr>
                </thead>

                <tbody id="myTable">

                    <% for (var i = 0; i < employeelist.length; i++) { %>

                    <tr>

                        <td>
                            <strong>
                                <%= employeelist[i].emp_name %>
                            </strong>
                        </td>

                        <td>
                            <%= employeelist[i].year_of_joining %>
                        </td>

                        <td>
                            <%= employeelist[i].gender %>
                        </td>

                        <td>
                            <%= employeelist[i].mob %>
                        </td>

                        <td>
                            <%= employeelist[i].remarks %>
                        </td>

                        <td style="text-align:center;">

                            <a href='/edit-empl/<%= employeelist[i]._id %>'
                                class="btn btn-primary"
                                style="padding:8px 12px; font-size:0.85rem;">

                                <i class="fa fa-edit"></i>
                                Edit

                            </a>

                        </td>

                    </tr>

                    <% } %>

                </tbody>

            </table>

        </div>

    </div>

    <% } else { %>

    <div class="card flex-center" style="flex-direction:column; padding:60px 20px;">

        <i class="fa fa-folder-open"
            style="font-size:60px; color: var(--text-light); margin-bottom:20px;">
        </i>

        <h3 style="margin-bottom:10px;">
            No Employee Records Found
        </h3>

        <p style="color: var(--text-light); margin-bottom:25px;">
            Start by adding your first employee record.
        </p>

        <a href="./employees" class="btn btn-primary">
            <i class="fa fa-plus"></i>
            Add Employee
        </a>

    </div>

    <% } %>

</div>

<%- include('footer'); -%>