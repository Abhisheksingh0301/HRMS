<title>
    <%= title %>
</title>

<link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/font-awesome/4.4.0/css/font-awesome.min.css" />
<script src="https://kit.fontawesome.com/00d76a4bef.js" crossorigin="anonymous"></script>

<link rel='stylesheet' href='/stylesheets/style.css'>
<script src="/js/jquery.js"></script>

<%- include('header'); -%>

<!-- PAGE HEADER -->
<section class="bg-gradient-to-r from-blue-600 to-indigo-700 py-4 shadow-md">

    <div class="max-w-7xl mx-auto px-4">

        <div class="text-center">

            <h1 class="text-2xl font-bold text-white flex items-center justify-center gap-3">
                <i class="fa fa-users"></i>
                <%= title %>
            </h1>

            <p class="text-blue-100 text-sm mt-1">
                Employee Management Dashboard
            </p>

        </div>

    </div>

</section>

<!-- MAIN CONTENT -->
<div class="max-w-7xl mx-auto px-4 py-6">

    <% if(employeelist.length > 0){ %>

    <!-- CARD -->
    <div class="bg-white rounded-2xl shadow-md border border-slate-200 overflow-hidden">

        <!-- TOP BAR -->
        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-3 px-5 py-4 border-b border-slate-200">

            <h2 class="text-lg font-bold text-slate-800">
                Employee Records
            </h2>

            <a href="./employees"
                class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold px-4 py-2 rounded-lg shadow transition">

                <i class="fa fa-plus"></i>
                Add Employee

            </a>

        </div>

        <!-- TABLE -->
        <div class="overflow-x-auto pb-16">

            <table class="min-w-full text-sm">

                <thead class="bg-slate-100 text-slate-700">
                    <tr>
                        <th class="text-left px-5 py-3 font-semibold">Name</th>
                        <th class="text-left px-5 py-3 font-semibold">Joining Year</th>
                        <th class="text-left px-5 py-3 font-semibold">Gender</th>
                        <th class="text-left px-5 py-3 font-semibold">Mobile No</th>
                        <th class="text-left px-5 py-3 font-semibold">Remarks</th>
                        <th class="text-center px-5 py-3 font-semibold">Action</th>
                    </tr>
                </thead>

                <tbody class="divide-y divide-slate-200">

                    <% for (var i = 0; i < employeelist.length; i++) { %>

                    <tr class="hover:bg-slate-50 transition">

                        <td class="px-5 py-3 font-semibold text-slate-800">
                            <%= employeelist[i].emp_name %>
                        </td>

                        <td class="px-5 py-3 text-slate-600">
                            <%= employeelist[i].year_of_joining %>
                        </td>

                        <td class="px-5 py-3 text-slate-600">
                            <%= employeelist[i].gender %>
                        </td>

                        <td class="px-5 py-3 text-slate-600">
                            <%= employeelist[i].mob %>
                        </td>

                        <td class="px-5 py-3 text-slate-600">
                            <%= employeelist[i].remarks %>
                        </td>

                        <td class="px-5 py-3 text-center">

                            <a href="/edit-empl/<%= employeelist[i]._id %>"
                                class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white text-xs font-semibold px-3 py-1.5 rounded-lg transition">

                                <i class="fa fa-edit"></i>
                                Edit

                            </a>

                        </td>

                    </tr>

                    <% } %>

                </tbody>

            </table>

        </div>

    </div>

    <% } else { %>

    <!-- EMPTY STATE -->
    <div class="bg-white rounded-2xl shadow-md border border-slate-200 p-10 text-center">

        <i class="fa fa-folder-open text-6xl text-slate-300 mb-4"></i>

        <h3 class="text-lg font-bold text-slate-800 mb-2">
            No Employee Records Found
        </h3>

        <p class="text-slate-500 mb-6">
            Start by adding your first employee record.
        </p>

        <a href="./employees"
            class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white font-semibold px-5 py-2.5 rounded-lg shadow transition">

            <i class="fa fa-plus"></i>
            Add Employee

        </a>

    </div>

    <% } %>

</div>

<%- include('footer'); -%>