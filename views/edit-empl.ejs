<title>
    <%= title %>
</title>

<link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/font-awesome/4.4.0/css/font-awesome.min.css" />
<script src="https://kit.fontawesome.com/00d76a4bef.js" crossorigin="anonymous"></script>

<link rel='stylesheet' href='/stylesheets/style.css'>
<script src="/js/jquery.js"></script>

<%- include('header'); -%>

<!-- HEADER -->
<section class="bg-gradient-to-r from-blue-600 to-indigo-700 py-3 shadow-md">

    <div class="max-w-7xl mx-auto px-4">

        <h1 class="text-xl font-bold text-white flex items-center gap-2">

            <i class="fa fa-user-edit"></i>

            <%= title %>

        </h1>

    </div>

</section>

<!-- MAIN -->
<div class="max-w-3xl mx-auto px-4 py-3">

    <div class="bg-white rounded-xl shadow-md border border-slate-200 p-4">

        <form action="/edit-empl/" method="POST" class="space-y-3">

            <input type="hidden" name="id" value="<%= empdata._id %>">

            <!-- EMP NAME (READONLY) -->
            <div class="relative">

                <input
                    type="text"
                    name="empname"
                    readonly
                    value="<%= empdata.emp_name %>"
                    class="peer w-full bg-slate-100 border border-slate-200 rounded-lg px-3 pt-5 pb-2 text-sm">

                <label class="absolute left-3 top-1 text-xs text-slate-500 peer-focus:text-blue-600">
                    Employee Name
                </label>

            </div>

            <!-- JOIN YEAR -->
            <div class="relative">

                <input
                    type="number"
                    name="joinyr"
                    value="<%= empdata.year_of_joining %>"
                    class="peer w-full border border-slate-300 rounded-lg px-3 pt-5 pb-2 text-sm focus:border-blue-500 outline-none">

                <label class="absolute left-3 top-1 text-xs text-slate-500">
                    Joining Year
                </label>

            </div>

            <!-- GENDER -->
            <div class="relative">

                <select
                    name="cmbGender"
                    class="peer w-full border border-slate-300 rounded-lg px-3 pt-5 pb-2 text-sm focus:border-blue-500 outline-none">

                    <option value="Male" <% if(empdata.gender=="Male"){ %> selected <% } %>>Male</option>
                    <option value="Female" <% if(empdata.gender=="Female"){ %> selected <% } %>>Female</option>

                </select>

                <label class="absolute left-3 top-1 text-xs text-slate-500">
                    Gender
                </label>

            </div>

            <!-- MOBILE -->
            <div class="relative">

                <input
                    type="number"
                    name="txtmob"
                    value="<%= empdata.mob %>"
                    class="peer w-full border border-slate-300 rounded-lg px-3 pt-5 pb-2 text-sm focus:border-blue-500 outline-none">

                <label class="absolute left-3 top-1 text-xs text-slate-500">
                    Mobile Number
                </label>

            </div>

            <!-- REMARKS -->
            <div class="relative">

                <input
                    type="text"
                    name="rmrk"
                    value="<%= empdata.remarks %>"
                    class="peer w-full border border-slate-300 rounded-lg px-3 pt-5 pb-2 text-sm focus:border-blue-500 outline-none">

                <label class="absolute left-3 top-1 text-xs text-slate-500">
                    Remarks
                </label>

            </div>

            <!-- BUTTON -->
            <button
                type="submit"
                class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 rounded-lg text-sm">

                <i class="fa fa-save mr-1"></i>
                Update

            </button>

        </form>

    </div>

</div>

<%- include('footer'); -%>